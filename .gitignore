# =============================================================================
# nuclide-method .gitignore
# Public methodology repo. The redaction boundary is enforced here AND in CI
# (.github/workflows/boundary-audit.yml). This file is the first line; CI is the
# second. Nothing raw, nothing live, nothing operator-identifying lands here.
# =============================================================================

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS cruft ---
.DS_Store
Thumbs.db

# --- Local notes / scratch (keep anything unpushed under scratch/) ---
scratch/
scratch/data/
*.local.md
notes.local/

# --- Python (future tooling) ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# --- Node ---
node_modules/

# --- Session and continuity state (local working memory, never public) ---
SESSION.md
.remember/

# =============================================================================
# REDACTION-BOUNDARY GAP-CLOSERS
# These patterns never existed in the source repo's ignore set and let raw
# recon leak by name. They are the load-bearing additions for a public repo.
# =============================================================================

# --- Whole evidence and recon trees (raw host data, harvest logs, scripts) ---
evidence/
recon/

# --- Dated survey output dirs: data/YYYY_MM_DD_<n>/ and IP-shaped dirnames.
#     Tools write to ./<IP-with-dots-as-underscores>/ when -out is relative;
#     the numeric-quad pattern catches both. ---
data/[0-9]*_[0-9]*_[0-9]*_[0-9]*/
/[0-9]*_[0-9]*_[0-9]*_[0-9]*/

# --- Bulk machine-readable scan output (line-delimited / compressed JSON) ---
*.ndjson
*.json.gz

# --- Findings ledgers and harvested host databases (raw creds / claim keys) ---
*.db
*.db.bak*
/empire.db

# --- Live scan state files (auth headers, tokens, system prompts, claim keys) ---
state.json
*-state.json
*-state-fresh.json
tokens.json
*ssh_key*

# --- Machine-readable IP / target lists (the core leak class) ---
ips*.txt
targets*.txt
target.txt
confirmed-ips*
*confirmed-ips*.txt

# --- Per-host dossiers and attribution maps ---
*-dossiers.json
*_dossiers.json
operator_attribution.json
per_ip_map.json
master_ip_index.json
FULL-IP-MAP.md

# --- Raw aimap / scanner output (capture Authorization headers and host detail) ---
**/aimap-*.json
**/aimap_*.json
**/aimap-results/*.json

# --- Raw API / HTTP captures ---
**/*openapi*.json
**/*.http
**/shodan-raw.json
**/shodan-host.json
shodan/**/scan_results.jsonl

# --- Disclosure routing (recipients / drafts) never belongs in a public repo ---
**/_gmail_drafts*
**/*ready-to-send*
disclosures/_gmail_drafts.json
